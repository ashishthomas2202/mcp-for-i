{
  "name": "mcp-for-i",
  "version": "0.1.11",
  "private": false,
  "description": "Local MCP server and control plane for IBM i workflows",
  "type": "module",
  "homepage": "https://github.com/ashishthomas2202/mcp-for-i",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ashishthomas2202/mcp-for-i.git"
  },
  "bugs": {
    "url": "https://github.com/ashishthomas2202/mcp-for-i/issues"
  },
  "files": [
    "dist",
    "README.md",
    "docs"
  ],
  "bin": {
    "mcp-for-i": "dist/index.js",
    "mcp-for-i-control": "dist/controlplane/index.js"
  },
  "scripts": {
    "prepack": "npm run build",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "start:controlplane": "node dist/controlplane/index.js",
    "dev": "ts-node src/index.ts",
    "dev:controlplane": "ts-node src/controlplane/index.ts",
    "test": "npm run build && node --test test/tools.test.mjs test/variables.test.mjs test/validation.test.mjs test/config.migration.test.mjs test/sql.parse.test.mjs test/audit.chain.test.mjs",
    "test:all": "npm run build && node --test test/*.mjs",
    "test:ibmi": "npm run build && node --test test/ibmi.integration.test.mjs",
    "test:mcp": "npm run build && node --test test/mcp.integration.test.mjs",
    "release:auto": "node scripts/release-auto.mjs patch",
    "release:patch": "node scripts/release-auto.mjs patch",
    "release:minor": "node scripts/release-auto.mjs minor",
    "release:major": "node scripts/release-auto.mjs major"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.25.3",
    "diff": "^5.2.0",
    "keytar": "^7.9.0",
    "node-ssh": "^13.1.0",
    "zod-to-json-schema": "^3.23.2"
  },
  "devDependencies": {
    "@types/diff": "^7.0.2",
    "dotenv": "^17.2.3",
    "ts-node": "^10.9.0",
    "typescript": "^5.4.0"
  }
}
